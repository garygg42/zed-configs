// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "vim_mode == normal && Editor",
    "bindings": {
      "H": "pane::ActivatePreviousItem",
      "L": "pane::ActivateNextItem",
      "M": "pane::CloseActiveItem",
      "space m o": "pane::CloseOtherItems",
      "space m l": "pane::CloseItemsToTheLeft",
      "space m r": "pane::CloseItemsToTheRight",
      "space e": "pane::RevealInProjectPanel",
      "space o": "file_finder::Toggle",
      "space O": "workspace::Open",
      "space c f": "editor::Format",
      "space r r": "task::Spawn",
      "space r a": "task::Rerun",
      "ctrl-j": "editor::AddSelectionBelow",
      "ctrl-k": "editor::AddSelectionAbove",
      "g m": "outline::Toggle",
      "g e": "editor::GoToDiagnostic",
      "g E": "editor::GoToPreviousDiagnostic",
    },
  },
  {
    "context": "os == windows || os == linux",
    "bindings": {
      "ctrl-N": "workspace::NewWindow",
      "ctrl-R": "projects::OpenRecent",
      "ctrl-O": "workspace::Open",
    },
  },
  {
    "context": "(os == windows || os == linux) && Editor",
    "bindings": {
      "ctrl-a": "editor::SelectAll",
      "ctrl-c": "editor::Copy",
      "ctrl-v": "editor::Paste",
    },
  },
  {
    "context": "vim_mode == normal && Editor && (os == windows || os == linux)",
    "bindings": {
      "ctrl-f": "vim::Search",
    },
  },
  {
    "context": "os == macos",
    "bindings": {
      "super-N": "workspace::NewWindow",
      "super-R": "projects::OpenRecent",
      "super-O": "workspace::Open",
    },
  },
]
